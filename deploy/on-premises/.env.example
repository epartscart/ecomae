# ecomae ERP — On-Premises Configuration
# Copy this to .env and fill in your values

# Application
APP_URL=https://erp.yourcompany.com
APP_ENV=production
TIMEZONE=Asia/Dubai

# Source of the application code that install.sh clones into ./app.
# If this repo is private, use a URL with an embedded deploy token/PAT, e.g.
# https://<token>@github.com/epartscart/ecomae.git
GIT_REPO_URL=https://github.com/epartscart/ecomae.git
GIT_REPO_REF=main

# License (obtain from your ecomae account manager, or generate one yourself
# on the platform server with: php epc-onprem-license-generate.php --customer "..." --tier professional)
LICENSE_KEY=LIC-2026-XXXX-XXXX

# Database
DB_DATABASE=ecomae_erp
DB_USERNAME=ecomae
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_HERE
DB_EXTERNAL_PORT=3306

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Ports (change if running behind reverse proxy)
HTTP_PORT=80
HTTPS_PORT=443

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_REMOTE_URL=

# BOS health reporting (optional — leave "disabled" for fully air-gapped mode).
# Authenticated by LICENSE_KEY itself; no separate token needed.
BOS_SYNC_MODE=disabled
# Options: disabled, monitoring_only

# Email (for report scheduling and notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=erp@yourcompany.com

# Company (used only to pre-fill onboarding at /cp/ — the actual company
# profile and admin account are created there, not by this file)
COMPANY_NAME=Your Company
COMPANY_COUNTRY=AE
COMPANY_CURRENCY=AED
COMPANY_TRN=
