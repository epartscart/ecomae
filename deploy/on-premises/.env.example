# ecomae ERP — On-Premises Configuration
# Copy this to .env and fill in your values

# Application
APP_URL=https://erp.yourcompany.com
APP_ENV=production
TIMEZONE=Asia/Dubai

# License (obtain from ecomae BOS → On-Premises → Generate License)
LICENSE_KEY=LIC-XXXX-XXXX-XXXX

# Database
DB_DATABASE=ecomae_erp
DB_USERNAME=ecomae
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_HERE
DB_EXTERNAL_PORT=3306

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Ports (change if running behind reverse proxy)
HTTP_PORT=80
HTTPS_PORT=443

# Backup
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_REMOTE_URL=

# BOS Connector (optional — leave empty for air-gapped mode)
BOS_CONNECTOR_URL=
BOS_CONNECTOR_TOKEN=
BOS_SYNC_MODE=disabled
# Options: disabled, monitoring_only, updates_only, full_sync

# Email (for report scheduling and notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=erp@yourcompany.com

# Company
COMPANY_NAME=Your Company
COMPANY_COUNTRY=AE
COMPANY_CURRENCY=AED
COMPANY_TRN=
